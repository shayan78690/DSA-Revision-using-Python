class Solution:
        
    def kadanes(self, arr):
        maxi = arr[0]
        curr = arr[0]
        for i in range(1, len(arr)):
            curr = max(curr+arr[i], arr[i])
            maxi = max(maxi, curr)
        return maxi
    
    def maxRectSum(self, mat):
        rows = len(mat)
        cols = len(mat[0])
        maxi = float('-inf')
        for left in range(cols):
            temp = [0] * rows
            for right in range(left, cols):
                for row in range(rows):
                    temp[row] += mat[row][right]
                maxi = max(maxi, self.kadanes(temp))
        return maxi
